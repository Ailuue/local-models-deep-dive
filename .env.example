# Copy this file to `.env` and adjust only if your local server isn't the default.
#
#   cp .env.example .env
#
# There is NO API key here — the model runs on your machine. The SDK still wants
# *some* api_key string, but the local server ignores it. NEVER commit your .env
# (it's already in .gitignore) even though it holds no secret, to keep habits good.

# ---------------------------------------------------------------------------
# Where is your local, OpenAI-compatible server?
#
#   Ollama      -> http://localhost:11434/v1   (the DEFAULT; just run Ollama)
#   LM Studio   -> http://localhost:1234/v1
#   llama.cpp   -> http://localhost:8080/v1    (llama-server)
#   vLLM        -> http://localhost:8000/v1
# ---------------------------------------------------------------------------
OPENAI_BASE_URL=http://localhost:11434/v1

# The chat model tag to talk to. With Ollama this is whatever you `ollama pull`ed.
# Good small starters: llama3.2 (3B), qwen2.5 (7B), phi3.5 (3.8B), mistral (7B).
LOCAL_MODEL=llama3.2

# A small local embedding model (Section 7). With Ollama: `ollama pull nomic-embed-text`.
LOCAL_EMBED_MODEL=nomic-embed-text

# The SDK requires a key string; the local server ignores it, so any value works.
OPENAI_API_KEY=local-no-key-needed
